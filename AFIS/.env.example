# AFIS Environment Configuration
# Copy this file to .env and fill in your values
# The system runs without any API keys (offline mode)

# Optional: Enable LLM-powered AI analysis
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Override default server port (default: 8000)
# PORT=8000

# Optional: Override database path (default: afis_finance.db)
# DATABASE_PATH=afis_finance.db
